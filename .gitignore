# Compiled binary
bin/

# Docker managed-plugin rootfs export — generated by plugin/Makefile's
# `install` target (docker export | tar -x), never source.
plugin/rootfs/

# Go test and coverage artifacts
*.test
*.out
coverage.html
coverage.txt

# Environment files — never commit real secrets
.env
.env.local
examples/**/.env

# Generated compose files — created by `docker-orbit generate`, not source
examples/testapp/docker-rollout-compose.yml
examples/advanced/docker-rollout-compose.yml
examples/basic/docker-rollout-compose.yml

# Orbit runtime state (rollout lock + state files written to /tmp)
*.lock
orbit-*-state.json

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Claude Code settings (local only)
.claude/

# Dependency cache (shouldn't be here but just in case)
vendor/
/dist/

# Stray JS/Node tooling artifacts — this is a Go project; no package.json or
# next.config.js exists at the root. If these reappear, something outside
# this project (a misconfigured tool, wrong cwd) is generating them.
node_modules/
.next/
next-env.d.ts
tsconfig.tsbuildinfo
